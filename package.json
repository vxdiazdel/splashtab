{
  "name": "splashtab",
  "version": "0.0.1",
  "description": "Load a new image from unsplash in each tab",
  "main": "script.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "./node_modules/.bin/babel script.js --out-file script.min.js",
